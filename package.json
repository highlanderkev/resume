{
  "name": "resume",
  "version": "1.0.0",
  "description": "Repo for Resume",
  "main": "index.js",
  "scripts": {
    "serve": "resume serve",
    "validate": "resume validate",
    "export:pdf": "resume export resume.pdf --format pdf --theme short",
    "export:html": "resume export resume.html --format html --theme direct",
    "extract": "node extract-resumes.js",
    "parse": "node resume-parser.js",
    "pipeline": "node pipeline.js",
    "pipeline:clean": "rm -rf extracted_data && mkdir -p extracted_data",
    "pipeline:full": "npm run pipeline:clean && npm run pipeline",
    "test": "npm run validate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/highlanderkev/resume.git"
  },
  "author": "highlanderkev",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/highlanderkev/resume/issues"
  },
  "homepage": "https://github.com/highlanderkev/resume#readme",
  "devDependencies": {
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.1.200",
    "resume-cli": "^3.0.8"
  },
  "dependencies": {
    "jsonresume-theme-compact": "^1.0.4",
    "jsonresume-theme-direct": "^0.1.1",
    "jsonresume-theme-elegant": "^1.16.1",
    "jsonresume-theme-flat": "^0.3.7",
    "jsonresume-theme-onepage": "^0.0.3",
    "jsonresume-theme-short": "^0.1.7"
  }
}
